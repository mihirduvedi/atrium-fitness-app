{
  "expo": {
    "name": "Atrium",
    "slug": "atrium",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "atrium",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.atrium.mobile"
    },
    "android": {
      "package": "app.atrium.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#FBFBF9",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FBFBF9",
          "dark": { "backgroundColor": "#1A1918" }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
